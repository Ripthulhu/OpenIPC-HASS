{
  "domain": "openipc",
  "name": "OpenIPC Camera",
  "codeowners": ["@Ripthulhu"],
  "config_flow": true,
  "dependencies": [
    "stream",
    "ssdp",
    "zeroconf",
    "telegram_bot",
    "media_player",
    "http"
  ],
  "documentation": "https://github.com/Ripthulhu/OpenIPC-HASS",
  "integration_type": "device",
  "iot_class": "local_polling",
  "issue_tracker": "https://github.com/Ripthulhu/OpenIPC-HASS/issues",
  "requirements": [
    "aiohttp>=3.8.0",
    "async-timeout>=4.0.0",
    "aiofiles>=23.2.0",
    "beward==1.1.4"
  ],
  "ssdp": [
    {
      "st": "urn:schemas-upnp-org:device:Basic:1",
      "manufacturer": "OpenIPC"
    }
  ],
  "version": "2.3.3",
  "zeroconf": [
    "_openipc._tcp.local.",
    "_http._tcp.local.",
    "_beward._tcp.local."
  ]
}
